<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="yahboom_2wd">
  <xacro:arg name="robot_name" default="yahboom_2wd"/>
  <xacro:arg name="wheel_radius" default="0.035"/>
  <xacro:arg name="wheel_separation" default="0.148"/>
  <xacro:arg name="chassis_length" default="0.228"/>
  <xacro:arg name="chassis_width" default="0.148"/>
  <xacro:arg name="chassis_height" default="0.040"/>

  <xacro:property name="wheel_radius" value="$(arg wheel_radius)"/>
  <xacro:property name="wheel_separation" value="$(arg wheel_separation)"/>
  <xacro:property name="chassis_length" value="$(arg chassis_length)"/>
  <xacro:property name="chassis_width" value="$(arg chassis_width)"/>
  <xacro:property name="chassis_height" value="$(arg chassis_height)"/>
  <xacro:property name="wheel_width" value="0.026"/>
  <xacro:property name="drive_x" value="-0.045"/>
  <xacro:property name="caster_x" value="0.075"/>

  <material name="dark_gray"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
  <material name="black"><color rgba="0.02 0.02 0.02 1.0"/></material>
  <material name="blue"><color rgba="0.05 0.2 0.8 1.0"/></material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_height/2.0}" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2.0}" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${chassis_height/2.0}" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.038" ixy="0" ixz="0" iyy="0.045" iyz="0" izz="0.052"/>
    </inertial>
  </link>

  <xacro:macro name="drive_wheel" params="side y">
    <link name="${side}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.20"/>
        <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00015"/>
      </inertial>
    </link>
    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${side}_wheel_link"/>
      <origin xyz="${drive_x} ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel side="left" y="${wheel_separation/2.0}"/>
  <xacro:drive_wheel side="right" y="${-wheel_separation/2.0}"/>

  <xacro:macro name="caster" params="side y">
    <link name="${side}_front_caster_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.0125"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.0125"/></geometry>
      </collision>
      <inertial>
        <mass value="0.03"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    <joint name="${side}_front_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${side}_front_caster_link"/>
      <origin xyz="${caster_x} ${y} -0.020" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:caster side="left" y="${chassis_width/2.0 - 0.025}"/>
  <xacro:caster side="right" y="${-chassis_width/2.0 + 0.025}"/>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.030 0.020 0.006"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.000 0.000 0.055" rpy="0 0 0"/>
  </joint>
</robot>
